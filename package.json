{
  "name": "scoutcard",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "generate": "tsx src/cli.ts",
    "build:sample": "tsx scripts/build-sample.ts",
    "generate:sample": "tsx src/cli.ts --export sample/sample-export.zip --country US --out sample/sample-card.svg",
    "dev:web": "vite web --config vite.config.ts",
    "build:web": "vite build web --config vite.config.ts --outDir dist --emptyOutDir"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "flag-icons": "^7.5.0",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^4.10.38"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
